# Encryption key for enc: secrets in clients.yml and users.yml — generate with: openssl rand -base64 32
NYX_SECRET=

# Public URL this service is served at (used as OIDC issuer)
NYX_URL=https://auth.example.com

# Comma-separated list of allowed CORS origins (apps that use this IdP)
TRUSTED_ORIGINS=https://admin.example.com

# Optional: JSON-serialized ES256 private key JWK for stable multi-replica signing
# Generate with: bun -e "import {generateKeyPair,exportJWK} from 'jose'; const {privateKey}=await generateKeyPair('ES256',{extractable:true}); console.log(JSON.stringify(await exportJWK(privateKey)))"
SIGNING_PRIVATE_JWK=

# Port to listen on (default: 3000)
PORT=3000
